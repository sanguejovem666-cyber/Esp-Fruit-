-- === FUNÇÃO DE AUTO-EXECUÇÃO E RESILIÊNCIA ===
local function IniciarRotinaDeServidor()
    AI:Log("Detectando estado do servidor...")
    
    -- 1. Garante que o personagem existe antes de começar
    local char = Player.Character or Player.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart", 10)
    if not root then return end
    
    -- 2. Limpa qualquer estabilizador antigo de uma execução anterior (Anti-Bug)
    for _, v in ipairs(root:GetChildren()) do
        if v.Name == "VorticeGyro" or v.Name == "VorticeVel" then v:Destroy() end
    end
    
    -- 3. Execução da IA e Lógica de Treino
    task.spawn(function()
        AI:Log("Iniciando rotina de treino...")
        
        -- Garante Team Pirata
        local entrou = false
        for i = 1, 10 do
            if Player.Team and Player.Team.Name == "Pirates" then entrou = true break end
            local pt = Teams:FindFirstChild("Pirates")
            if pt then Player.Team = pt end
            task.wait(0.5)
        end
        
        -- Roda ciclo de Skills
        AI:RunCycle()
        
        -- Voa e trava
        local gyro, vel = VooEstatico()
        
        -- Espera treino
        task.wait(tempoEsperaE)
        
        -- Hop Automático
        SmartServerHop()
    end)
end

