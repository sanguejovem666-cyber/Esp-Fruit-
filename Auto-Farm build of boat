local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

-- Configurações
local active = false
local velocidade = 250          -- Ajuste aqui (estudos por segundo)
local tempoParado = 1.5        -- Tempo parado em cada ponto

local coords = {
	Vector3.new(-51.81, 100.51, 1335.00),
	Vector3.new(-62.71, 95.73, 1388.77),
	Vector3.new(-41.52, 96.18, 2113.93),
	Vector3.new(-39.83, 105.21, 2162.35),
	Vector3.new(-46.74, 108.86, 2929.91),
	Vector3.new(-50.56, 27.28, 3647.41),
	Vector3.new(-53.73, 49.79, 3699.02),
	Vector3.new(-57.28, 88.42, 4411.10),
	Vector3.new(-61.39, 37.21, 5186.54),
	Vector3.new(-62.03, 72.91, 6003.12)
}

local plataformaAtual = nil

-- Função para criar plataforma de apoio (visual + colisão)
local function criarPlataforma(posicao)
	if plataformaAtual then
		plataformaAtual:Destroy()
	end
	
	local part = Instance.new("Part")
	part.Size = Vector3.new(8, 1, 8)
	part.Position = posicao - Vector3.new(0, 3.8, 0)
	part.Anchored = true
	part.Transparency = 0.6
	part.BrickColor = BrickColor.new("Cyan")
	part.CanCollide = true
	part.Parent = workspace
	
	plataformaAtual = part
end

-- Função principal de voo suave e reto
local function voarPara(targetPos)
	local character = player.Character
	if not character then return end
	
	local root = character:FindFirstChild("HumanoidRootPart")
	local humanoid = character:FindFirstChild("Humanoid")
	if not root or not humanoid then return end
	
	-- Salva a rotação atual (para não girar o personagem desnecessariamente)
	local currentCFrame = root.CFrame
	local targetCFrame = CFrame.new(targetPos) * (currentCFrame - currentCFrame.Position)  -- mantém rotação
	
	local distancia = (root.Position - targetPos).Magnitude
	local tempo = distancia / velocidade
	
	-- Ancorar para eliminar tremor da física
	root.Anchored = true
	
	local tweenInfo = TweenInfo.new(
		tempo,
		Enum.EasingStyle.Linear,     -- movimento reto e constante
		Enum.EasingDirection.Out
	)
	
	local tween = TweenService:Create(root, tweenInfo, {CFrame = targetCFrame})
	tween:Play()
	
	tween.Completed:Wait()
	
	-- Desancora após o voo
	root.Anchored = false
	
	-- Cria plataforma para estabilizar
	criarPlataforma(targetPos)
end

-- Interface
local screenGui = Instance.new("ScreenGui")
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

