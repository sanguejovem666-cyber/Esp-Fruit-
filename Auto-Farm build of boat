-- Loop principal
task.spawn(function()
	while true do
		if active then
			for i, pos in ipairs(coords) do
				if not active then break end
				
				voarPara(pos)
				task.wait(tempoParado)
				
				-- Último ponto: reseta e morre para repetir
				if i == #coords and active then
					if plataformaAtual then
						plataformaAtual:Destroy()
						plataformaAtual = nil
					end
					
					local character = player.Character
					if character and character:FindFirstChild("Humanoid") then
						character.Humanoid.Health = 0
					end
					
					player.CharacterAdded:Wait()
					task.wait(2)
				end
			end
		end
		task.wait(0.3)
	end
end)

-- Botão
button.MouseButton1Click:Connect(function()
	active = not active
	
	if active then
		button.Text = "AUTO-VÔO: ON"
		button.TextColor3 = Color3.fromRGB(0, 255, 100)
		button.BackgroundColor3 = Color3.fromRGB(30, 50, 30)
	else
		button.Text = "AUTO-VÔO: OFF"
		button.TextColor3 = Color3.fromRGB(255, 80, 80)
		button.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
		
		if plataformaAtual then
			plataformaAtual:Destroy()
			plataformaAtual = nil
		end
	end
end)
