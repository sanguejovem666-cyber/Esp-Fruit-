--// FUNÇÃO DE VOAR (TWEEN TELEPORT)
local isFlying = false
local function voarPara(destinoCFrame, nomeDestino)
	local char = player.Character
	if char and char:FindFirstChild("HumanoidRootPart") and not isFlying then
		isFlying = true
		local hrp = char.HumanoidRootPart
		
		-- Calcula o tempo de voo baseado na distância e velocidade
		local distancia = (hrp.Position - destinoCFrame.Position).Magnitude
		local tempoDeVoo = distancia / VELOCIDADE_VOO
		
		-- Eleva um pouco o destino para não bater os pés no chão
		local cframeElevado = destinoCFrame + Vector3.new(0, 5, 0)
		
		-- Ancorar para evitar cair durante o voo
		hrp.Anchored = true
		
		local tween = TweenService:Create(hrp, TweenInfo.new(tempoDeVoo, Enum.EasingStyle.Linear), {CFrame = cframeElevado})
		tween:Play()
		
		Notify("🚀 Voando para " .. nomeDestino .. "...")
		
		tween.Completed:Connect(function()
			hrp.Anchored = false
			isFlying = false
			Notify("✅ Chegou em " .. nomeDestino .. "!")
		end)
	end
end

