-- ===================== MOVIMENTO DO TORNADO =====================
local function createTornado(pos)
	if tornadoCenter then tornadoCenter:Destroy() end
	tornadoCenter = Instance.new("Part", workspace)
	tornadoCenter.Name = "HydraVortice93"
	tornadoCenter.Size = Vector3.new(4,4,4)
	tornadoCenter.Anchored = true
	tornadoCenter.CanCollide = false
	tornadoCenter.Transparency = 1
	tornadoCenter.Position = pos
	
	visualPart = Instance.new("Part", tornadoCenter)
	visualPart.Size = Vector3.new(currentRadius,72,currentRadius)
	visualPart.Anchored = true
	visualPart.CanCollide = false
	visualPart.Shape = Enum.PartType.Cylinder
	visualPart.Orientation = Vector3.new(0,0,90)
	visualPart.Position = pos + Vector3.new(0,36,0)
	visualPart.Color = CONFIG.TornadoColor
	visualPart.Material = Enum.Material.ForceField
	visualPart.Transparency = 0.52
	
	RunService.RenderStepped:Connect(function()
		if visualPart and visualPart.Parent then
			visualPart.CFrame *= CFrame.Angles(math.rad(15),0,0)
		end
	end)
end

RunService.Heartbeat:Connect(function()
	if not tornadoCenter then return end

	if isFollowing then
		local camera = workspace.CurrentCamera
		local rayOrigin = camera.CFrame.Position
		local direction = (mouse.Hit.Position - rayOrigin).Unit * 600

		local params = RaycastParams.new()
		params.FilterDescendantsInstances = {player.Character, tornadoCenter}
		params.FilterType = Enum.RaycastFilterType.Exclude

		local result = workspace:Raycast(rayOrigin, direction, params)

		if result then
			local hitPos = result.Position
			local target = Vector3.new(hitPos.X, tornadoCenter.Position.Y, hitPos.Z)
			local moved = (target - lastMousePosition).Magnitude > MOUSE_MOVE_THRESHOLD

			if moved then
				tornadoCenter.Position = tornadoCenter.Position:Lerp(target, 0.2)
				lastMousePosition = target
				lastMouseUpdate = tick()
			end
		end
	elseif aiMode and savedHome then
		local t = tick() * CONFIG.RoamSpeed
		local angle = t % (math.pi*2)
		local offset = Vector3.new(
			math.sin(angle)*CONFIG.RoamRadius + math.noise(t*1.3)*35,
			math.noise(t*2)*12,
			math.cos(angle)*CONFIG.RoamRadius + math.noise(t*0.8+50)*35
		)
		local targetPos = savedHome + offset
		tornadoCenter.Position = tornadoCenter.Position:Lerp(targetPos, 0.085)
	end

	if visualPart then
		visualPart.Size = Vector3.new(currentRadius,72,currentRadius)
		visualPart.Position = tornadoCenter.Position + Vector3.new(0,36,0)
	end

	local params = OverlapParams.new()
	params.FilterDescendantsInstances = {tornadoCenter, player.Character}
	params.FilterType = Enum.RaycastFilterType.Exclude

	local parts = workspace:GetPartBoundsInRadius(tornadoCenter.Position, currentRadius, params)
	local pulled = 0

	for _,part in parts do
		if part:IsA("BasePart") and not part.Anchored then
			pulled += 1
			local dir = (tornadoCenter.Position - part.Position).Unit
			part.AssemblyLinearVelocity = dir * currentPull + Vector3.new(0,currentLift,0)
		end
	end

	if pulled > 0 then
		mass += pulled * 0.15
		currentRadius = math.clamp(CONFIG.Radius + mass * 0.92, CONFIG.Radius, 480)
		currentPull = math.clamp(CONFIG.PullStrength + mass * 4.2, CONFIG.PullStrength, 3800)
		currentLift = math.clamp(CONFIG.LiftStrength + mass * 2.1, CONFIG.LiftStrength, 1250)
	end
end)

--// CONTROLES DE TECLADO (Tornado + Voo)
UIS.InputBegan:Connect(function(i,gpe)
	if gpe then return end
	
	-- Atalhos de Teleporte
	if i.KeyCode == Enum.KeyCode.K then
		voarPara(COORD_BASE, "A Base")
	elseif i.KeyCode == Enum.KeyCode.L then
		voarPara(COORD_JOGO, "O Jogo")
		
	-- Atalhos do Tornado
	elseif i.KeyCode == Enum.KeyCode.Z then
		if not tornadoCenter then createTornado(mouse.Hit.Position) end
		isFollowing = not isFollowing
		aiMode = false
		Notify("FOLLOW MOUSE: "..(isFollowing and "ON" or "OFF"))
	elseif i.KeyCode == Enum.KeyCode.C then
		savedHome = mouse.Hit.Position
		Notify("HOME SALVO - IA rondando")
	elseif i.KeyCode == Enum.KeyCode.X then
		if not tornadoCenter then createTornado(mouse.Hit.Position) end
		aiMode = not aiMode
		isFollowing = false
		Notify("AI ROAMING: "..(aiMode and "ON" or "OFF"))
	elseif i.KeyCode == Enum.KeyCode.V then
		if not tornadoCenter then createTornado(mouse.Hit.Position) end
		attackMode = not attackMode
		if attackMode then rampStart = tick() end
		Notify(attackMode and "ATTACK ON" or "ATTACK OFF")
	end
end)

