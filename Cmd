consoleInput.FocusLost:Connect(function(enter)
	if enter then
		local cmd = consoleInput.Text
		addConsoleLine("> " .. cmd, Color3.fromRGB(0, 200, 255))
		if cmd:lower() == "clear" then
			for _, v in ipairs(consoleScroll:GetChildren()) do
				if v:IsA("TextLabel") then v:Destroy() end
			end
		else
			addConsoleLine("CMD executado: " .. cmd, Color3.fromRGB(255, 255, 100))
		end
		consoleInput.Text = ""
	end
end)

