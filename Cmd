local function createNormalButton(text)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -20, 0, 42)
	btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
	btn.Text = text
	btn.TextColor3 = Color3.fromRGB(0, 255, 0)
	btn.Font = Enum.Font.Code
	btn.TextSize = 17
	btn.Parent = exploitsScroll

	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 5)
	btnCorner.Parent = btn

	btn.MouseButton1Click:Connect(function()
		addConsoleLine("[EXEC] " .. text, Color3.fromRGB(0, 200, 255))
		
		-- Exemplos de funções reais (você pode expandir)
		if text == "Achar todas As Falhas Do jogo" or text == "Scan for Hidden Remotes" then
			local count = 0
			for _, obj in ipairs(game:GetDescendants()) do
				if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") or obj:IsA("BindableEvent") then
					count += 1
				end
			end
			addConsoleLine("Encontradas " .. count .. " falhas/remotes potenciais!", Color3.fromRGB(0, 255, 0))
		elseif text == "Kick All" or text == "Auto Kick All Players" then
			for _, plr in ipairs(Players:GetPlayers()) do
				if plr ~= player then
					pcall(function() plr:Kick("Kicked via CMD Exploit GUI") end)
				end
			end
		elseif text == "Controlar RemotEvents" or text == "Fire All Remotes" then
			addConsoleLine("Controle de RemotEvents aberto (use console para fire custom)", Color3.fromRGB(255, 200, 0))
		elseif text == "Ban All" then
			addConsoleLine("Tentativa de Ban All enviada (requer backdoor/server exploit)", Color3.fromRGB(255, 50, 50))
		else
			addConsoleLine("Funcionalidade pronta! Adicione seu código personalizado aqui dentro do script.", Color3.fromRGB(255, 255, 100))
		end
	end)
end

