local function addConsoleLine(text, color)
	local line = Instance.new("TextLabel")
	line.Size = UDim2.new(1, 0, 0, 22)
	line.BackgroundTransparency = 1
	line.Text = text
	line.TextColor3 = color or Color3.fromRGB(0, 255, 0)
	line.TextXAlignment = Enum.TextXAlignment.Left
	line.Font = Enum.Font.Code
	line.TextSize = 17
	line.Parent = consoleScroll
	consoleScroll.CanvasSize = UDim2.new(0, 0, 0, consoleLayout.AbsoluteContentSize.Y + 50)
	consoleScroll.CanvasPosition = Vector2.new(0, consoleScroll.CanvasSize.Y.Offset)
end

