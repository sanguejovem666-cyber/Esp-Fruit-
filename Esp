game.Players.LocalPlayer.Idled:Connect(function()
    VU:CaptureController()
    VU:ClickButton2(Vector2.new())
end)

local OrionLib = loadstring(game:HttpGet(('https://raw.githubusercontent.com/shlexware/Orion/main/source')))()
local Window = OrionLib:MakeWindow({Name = "Knup Hub | Full Edition 2026", HidePremium = false, SaveConfig = true, Theme = "Dark"})

-- Variáveis Globais
_G.FastAttack = false
_G.AutoFruit = false
_G.EspWorld = false
_G.HitboxSize = 35

-- [[ 2. FUNÇÕES DE SUPORTE ]]

-- Função de Armazenar Fruta (Seu código adaptado)
local function StoreFruit(fruitObj)
    local remote = game:GetService("ReplicatedStorage"):FindFirstChild("StoreFruit", true) or game:GetService("ReplicatedStorage"):FindFirstChild("FruitStorage", true)
    if remote then remote:FireServer(fruitObj.Name) end
end

-- Fast Attack Corrigido (50 CPS)
local function ExecuteFastAttack()
    pcall(function()
        local CF = require(game:GetService("ReplicatedStorage").CombatFramework)
        local RC = require(game:GetService("ReplicatedStorage").CombatFramework.RigController)
        local AC = CF.activeController
        if AC and AC.equippedWeapon then
            for i = 1, 15 do RC.attack(AC) end
        end
    end)
end

-- ESP Universal (Flores, Ilhas e Frutas)
local function CreateESP(Part, Name, Color)
    if not Part:FindFirstChild("KnupTag") then
        local b = Instance.new("BillboardGui", Part)
        b.Name = "KnupTag"
        b.AlwaysOnTop, b.Size, b.MaxDistance = true, UDim2.new(0, 100, 0, 40), 20000
        local l = Instance.new("TextLabel", b)
        l.Size, l.BackgroundTransparency, l.Text = UDim2.new(1,0,1,0), 1, Name
        l.TextColor3, l.TextScaled, l.TextStrokeTransparency = Color, true, 0
    end
end

-- [[ 3. ABAS DA INTERFACE ]]

