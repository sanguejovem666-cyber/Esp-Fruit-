-- [[ 4. LOOPS DE EXECUÇÃO (BACKGROUND) ]]

task.spawn(function()
    while true do
        task.wait(0.1)
        local lp = game.Players.LocalPlayer
        local char = lp.Character
        
        -- Lógica de Combate
        if _G.FastAttack and char then
            pcall(function()
                -- Auto-Equip
                if not char:FindFirstChildOfClass("Tool") then
                    local tool = lp.Backpack:GetChildren()[1]
                    if tool then char.Humanoid:EquipTool(tool) end
                end
                -- Hitbox e Ataque
                local weapon = char:FindFirstChildOfClass("Tool")
                if weapon and weapon:FindFirstChild("Handle") then
                    weapon.Handle.Size = Vector3.new(_G.HitboxSize, _G.HitboxSize, _G.HitboxSize)
                    weapon.Handle.CanCollide = false
                end
                ExecuteFastAttack()
            end)
        end

        -- Lógica de Frutas, Flores e Ilhas
        pcall(function()
            for _, v in pairs(workspace:GetChildren()) do
                -- ESP e Coleta de Frutas
                if v.Name:lower():find("fruit") or (v:IsA("Tool") and v.Name:lower():find("fruit")) then
                    local h = v:FindFirstChild("Handle") or v:FindFirstChildWhichIsA("BasePart", true)
                    if h then
                        CreateESP(h, "FRUIT", Color3.new(0, 1, 0))
                        if _G.AutoFruit and lp.Character then
                            local oldCF = lp.Character.HumanoidRootPart.CFrame
                            lp.Character.HumanoidRootPart.CFrame = h.CFrame
                            task.wait(0.2)
                            firetouchinterest(lp.Character.HumanoidRootPart, h, 0)
                            firetouchinterest(lp.Character.HumanoidRootPart, h, 1)
                            StoreFruit(v)
                            task.wait(0.2)
                            lp.Character.HumanoidRootPart.CFrame = oldCF
                        end
                    end
                end
                -- ESP Flores e Ilhas
                if _G.EspWorld then
                    if v.Name:find("Flower") then CreateESP(v, v.Name:upper(), Color3.new(1, 0, 0)) end
                    if v:IsA("Model") and (v.Name:find("Island") or v.Name:find("Map")) then
                        local c = v:FindFirstChildWhichIsA("BasePart")
                        if c then CreateESP(c, v.Name:upper(), Color3.new(0, 1, 1)) end
                    end
                end
            end
        end)
    end
end)

OrionLib:Init()
