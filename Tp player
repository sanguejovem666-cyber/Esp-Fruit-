--[[
    Vortice Hub - Teleport GUI Universal
    - Lista de players em tempo real
    - Teleporte Instantâneo
    - Chat Command Integration (/tp)
]]

local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local Player = Players.LocalPlayer

-- === CONSTRUTOR DA GUI ===
local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "VorticeTeleportHub"

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 200, 0, 300)
MainFrame.Position = UDim2.new(0, 50, 0.5, -150)
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.Active = true
MainFrame.Draggable = true -- Permite mover a janela

local ScrollingFrame = Instance.new("ScrollingFrame", MainFrame)
ScrollingFrame.Size = UDim2.new(1, -10, 1, -10)
ScrollingFrame.Position = UDim2.new(0, 5, 0, 5)
ScrollingFrame.BackgroundTransparency = 1
ScrollingFrame.ScrollBarThickness = 5

-- === FUNÇÃO DE TELEPORTE + CHAT ===
local function TeleportarParaPlayer(targetPlayer)
    if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
        -- 1. Teleporte Instantâneo
        Player.Character.HumanoidRootPart.CFrame = targetPlayer.Character.HumanoidRootPart.CFrame
        
        -- 2. Envia o comando no chat
        game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer("/tp " .. targetPlayer.Name, "All")
        
        print("Teleportado para: " .. targetPlayer.Name)
    end
end

-- === ATUALIZAÇÃO DA LISTA ===
local function AtualizarLista()
    -- Limpa a lista atual
    for _, child in ipairs(ScrollingFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    -- Adiciona players
    local yOffset = 0
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= Player then
            local btn = Instance.new("TextButton", ScrollingFrame)
            btn.Size = UDim2.new(1, -10, 0, 30)
            btn.Position = UDim2.new(0, 5, 0, yOffset)
            btn.Text = p.Name
            btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.MouseButton1Click:Connect(function()
                TeleportarParaPlayer(p)
            end)
            yOffset = yOffset + 35
        end
    end
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, yOffset)
end

-- Atualiza ao entrar ou sair players
Players.PlayerAdded:Connect(AtualizarLista)
Players.PlayerRemoving:Connect(AtualizarLista)
AtualizarLista()

print("Vortice Hub [Teleport GUI] carregado, Feito por HydraSpart.-.")
